@model CursoCreateViewModel
@{
    ViewData["Title"] = "Crear curso";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h1 class="h3 mb-3">Crear curso</h1>

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Materia" class="form-label"></label>
                        <input asp-for="Materia" class="form-control" />
                        <span asp-validation-for="Materia" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DocenteId" class="form-label"></label>
                        <select asp-for="DocenteId" asp-items="Model.Docentes" class="form-select">
                            <option value="">Seleccione un docente</option>
                        </select>
                        <span asp-validation-for="DocenteId" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Disponible" class="form-check-input" />
                        <label asp-for="Disponible" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary">Guardar</button>
                    <a asp-action="Index" class="btn btn-secondary">Volver</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
