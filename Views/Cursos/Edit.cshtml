@model AcademicManagementSystem.ViewModels.CursoCreateViewModel

@{
    ViewData["Title"] = "Editar Curso";
}

<h2>Editar Curso</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" class="form-control" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Materia"></label>
        <input asp-for="Materia" class="form-control" />
        <span asp-validation-for="Materia" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Descripcion"></label>
        <textarea asp-for="Descripcion" class="form-control"></textarea>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Disponible"></label>
        <input asp-for="Disponible" type="checkbox" />
    </div>

    <div class="form-group">
        <label asp-for="DocenteId">Docente</label>
        <select asp-for="DocenteId" asp-items="Model.Docentes" class="form-control">
            <option value="">-- Seleccione un docente --</option>
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}